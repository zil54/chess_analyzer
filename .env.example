# Database configuration (optional)
# Preferred single-URL form:
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/chess

# Or discrete DB_* settings:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chess
DB_USER=postgres
DB_PASSWORD=your_password_here
# DB_SSLMODE=disable

# Backend live-analysis defaults
LIVE_ANALYSIS_DISPLAY_TARGET_DEPTH=20
LIVE_ANALYSIS_WORKER_TARGET_DEPTH=26
LIVE_ANALYSIS_DISPLAY_LAG_DEPTH=2

